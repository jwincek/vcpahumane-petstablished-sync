<?xml version="1.0"?>
<ruleset name="Petstablished Sync">
	<description>WordPress coding standards for Petstablished Sync plugin.</description>

	<!-- What to scan: PHP only — JS and CSS are covered by
	     @wordpress/scripts (eslint / stylelint). -->
	<file>.</file>
	<arg name="extensions" value="php"/>

	<!-- Exclude paths -->
	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<!-- Dev-only tooling, not shipped in the plugin zip (see .distignore). -->
	<exclude-pattern>/migration-scripts/*</exclude-pattern>
	<exclude-pattern>/bin/*</exclude-pattern>

	<!-- Warnings stay visible but don't fail CI; errors do. -->
	<config name="ignore_warnings_on_exit" value="1"/>

	<!-- PHP compatibility -->
	<config name="testVersion" value="8.1-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- WordPress standards -->
	<config name="minimum_supported_wp_version" value="6.9"/>
	<rule ref="WordPress">
		<!-- Allow short array syntax (WPCS 3.x sniff name; the old
		     Generic.Arrays.DisallowShortArraySyntax no longer matches). -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<!-- Allow short closures and arrow functions -->
		<exclude name="Universal.FunctionDeclarations.NoLongClosures"/>
		<!-- House style: allow non-Yoda conditions and short ternaries. -->
		<exclude name="WordPress.PHP.YodaConditions"/>
		<exclude name="Universal.Operators.DisallowShortTernary"/>
		<!-- Docblock completeness (WordPress-Docs) is aspirational for
		     this codebase; re-enable and backfill incrementally. -->
		<exclude name="WordPress-Docs"/>
	</rule>

	<!-- PHP files under blocks/ (render.php and partials) are included
	     inside WP's render callback, so their variables are function-
	     scoped, not global — both sniffs false-positive on them. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound">
		<exclude-pattern>/blocks/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.WP.GlobalVariablesOverride.Prohibited">
		<exclude-pattern>/blocks/*</exclude-pattern>
	</rule>

	<!-- Plugin text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="shelter-pet-sync"/>
			</property>
		</properties>
	</rule>

	<!-- Prefixes for global functions, classes, hooks -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="petstablished"/>
				<element value="Petstablished"/>
				<element value="petsync"/>
				<element value="vcps"/>
			</property>
		</properties>
	</rule>
</ruleset>
