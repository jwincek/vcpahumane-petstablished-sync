{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "petstablished/pet-filters",
	"version": "2.1.0",
	"title": "Pet Filters",
	"category": "theme",
	"description": "Filter form for pet listings. Works without JavaScript via URL parameters.",
	"keywords": ["pet", "filter", "search", "adoption"],
	"textdomain": "petstablished-sync",
	"attributes": {
		"showAnimal": { "type": "boolean", "default": true },
		"showBreed": { "type": "boolean", "default": true },
		"showAge": { "type": "boolean", "default": true },
		"showSex": { "type": "boolean", "default": true },
		"showSize": { "type": "boolean", "default": true },
		"showStatus": { "type": "boolean", "default": false },
		"showCompatibility": { "type": "boolean", "default": true },
		"showGoodWithDogs": { "type": "boolean", "default": true },
		"showGoodWithCats": { "type": "boolean", "default": true },
		"showGoodWithKids": { "type": "boolean", "default": true },
		"showHealth": { "type": "boolean", "default": true },
		"showShotsCurrent": { "type": "boolean", "default": true },
		"showSpayedNeutered": { "type": "boolean", "default": true },
		"showHousebroken": { "type": "boolean", "default": true },
		"showSpecialNeeds": { "type": "boolean", "default": true },
		"compatibilityStyle": {
			"type": "string",
			"default": "checkboxes",
			"enum": ["checkboxes", "chips"]
		},
		"compatibilityCollapsed": { "type": "boolean", "default": false },
		"layout": {
			"type": "string",
			"default": "horizontal",
			"enum": ["horizontal", "vertical"]
		}
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": {
			"margin": true,
			"padding": true
		},
		"interactivity": true
	},
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"style": "file:./style.css"
}
