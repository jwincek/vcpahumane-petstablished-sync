{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "petsync/pet-compatibility",
	"version": "1.0.0",
	"title": "Pet Compatibility",
	"category": "petsync",
	"description": "Display pet compatibility with dogs, cats, and children.",
	"keywords": ["pet", "compatibility", "dogs", "cats", "kids", "good with"],
	"ancestor": ["petsync/pet-details"],
	"textdomain": "shelter-pet-sync",
	"usesContext": ["postId", "postType"],
	"attributes": {
		"showDogs": { "type": "boolean", "default": true },
		"showCats": { "type": "boolean", "default": true },
		"showKids": { "type": "boolean", "default": true },
		"displayStyle": {
			"type": "string",
			"default": "cards",
			"enum": ["cards", "stacked", "pills"]
		},
		"headingText": {
			"type": "string",
			"default": "Good with"
		},
		"positiveHeadingText": {
			"type": "string",
			"default": "Plays nicely with"
		}
	},
	"supports": {
		"html": false,
		"reusable": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"interactivity": true
	},
	"render": "file:./render.php",
	"style": "file:./style.css"
}
