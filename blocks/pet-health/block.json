{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "petstablished/pet-health",
	"version": "3.2.0",
	"title": "Pet Health",
	"category": "petstablished",
	"description": "Display pet health information like vaccinations, spay/neuter status, and more.",
	"keywords": ["pet", "health", "vaccinations", "spayed", "neutered", "hypoallergenic", "declawed"],
	"ancestor": ["petstablished/pet-details"],
	"textdomain": "petstablished-sync",
	"usesContext": ["postId", "postType"],
	"attributes": {
		"displayMode": {
			"type": "string",
			"default": "known",
			"enum": ["all", "known", "positive"]
		},
		"showSpayedNeutered": { "type": "boolean", "default": true },
		"showVaccinations": { "type": "boolean", "default": true },
		"showHousebroken": { "type": "boolean", "default": true },
		"showSpecialNeeds": { "type": "boolean", "default": true },
		"showHypoallergenic": { "type": "boolean", "default": true },
		"showDeclawed": { "type": "boolean", "default": true }
	},
	"supports": {
		"html": false,
		"reusable": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"interactivity": true
	},
	"render": "file:./render.php",
	"style": "file:./style.css"
}
