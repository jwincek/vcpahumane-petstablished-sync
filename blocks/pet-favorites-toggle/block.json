{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "petstablished/pet-favorites-toggle",
	"version": "2.0.0",
	"title": "Favorites Toggle",
	"category": "theme",
	"description": "Button to show only favorited pets in a listing.",
	"keywords": [
		"pet",
		"favorites",
		"filter"
	],
	"textdomain": "petstablished-sync",
	"attributes": {
		"showCount": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"interactivity": true
	},
	"render": "file:./render.php",
	"style": "file:./style.css"
}
