{
	"extends": [ "plugin:@wordpress/eslint-plugin/recommended" ],
	"env": {
		"browser": true
	},
	"rules": {
		"no-console": [ "error", { "allow": [ "error", "warn" ] } ],
		"jsdoc/require-param-type": "off"
	},
	"overrides": [
		{
			"files": [ "assets/js/blocks-editor.js", "assets/js/editor.js" ],
			"rules": {
				"react-hooks/rules-of-hooks": "off"
			}
		}
	]
}
