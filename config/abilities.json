{
  "abilities": {
    "petstablished/get-pet": {
      "label": "Get Pet",
      "description": "Retrieves a single pet by post ID with full hydrated data.",
      "category": "pets",
      "permission": "public",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Pet post ID."
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "description": "Hydrated pet entity.",
        "properties": {
          "id":                    { "type": "integer" },
          "name":                  { "type": "string" },
          "status":                { "type": "string" },
          "animal":                { "type": "string" },
          "breed":                 { "type": "string" },
          "age":                   { "type": "string" },
          "sex":                   { "type": "string" },
          "size":                  { "type": "string" },
          "color":                 { "type": "string" },
          "coat":                  { "type": "string" },
          "image":                 { "type": "string" },
          "url":                   { "type": "string" },
          "description":           { "type": "string" },
          "gallery":               { "type": "array", "items": { "type": "object" } },
          "gallery_count":         { "type": "integer" },
          "favorited":             { "type": "boolean" },
          "is_new":                { "type": "boolean" },
          "weight":                { "type": "string" },
          "adoption_fee":          { "type": "string" },
          "adoption_fee_formatted": { "type": "string" },
          "adoption_form_url":     { "type": "string" },
          "has_adoption_info":     { "type": "boolean" },
          "numerical_age":         { "type": "string" },
          "youtube_url":           { "type": "string" },
          "microchip_id":          { "type": "string" },
          "ok_with_dogs":          { "type": "string" },
          "ok_with_cats":          { "type": "string" },
          "ok_with_kids":          { "type": "string" },
          "shots_current":         { "type": "string" },
          "spayed_neutered":       { "type": "string" },
          "housebroken":           { "type": "string" },
          "special_needs":         { "type": "string" },
          "special_needs_detail":  { "type": "string" },
          "special_needs_summary": { "type": "string" },
          "hypoallergenic":        { "type": "string" },
          "declawed":              { "type": "string" },
          "coat_pattern":          { "type": "string" },
          "secondary_color":       { "type": "string" },
          "tertiary_color":        { "type": "string" },
          "is_bonded_pair":        { "type": "boolean" },
          "bonded_pair_names":     { "type": "array", "items": { "type": "object" } },
          "bonded_group_id":       { "type": "string" },
          "siblings_names":        { "type": "string" },
          "tagline":               { "type": "string" },
          "compatibility":         { "type": "string" },
          "story_title":           { "type": "string" },
          "adoption_title":        { "type": "string" }
        }
      }
    },

    "petstablished/list-pets": {
      "label": "List Pets",
      "description": "Retrieves a paginated list of pets with taxonomy and compatibility filters.",
      "category": "pets",
      "permission": "public",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "$ref": "schemas/taxonomy-filters.json",
        "type": "object",
        "properties": {
          "status":   { "type": "string", "default": "available", "description": "Filter by status slug." },
          "color":    { "type": "string", "description": "Filter by color slug." },
          "coat":     { "type": "string", "description": "Filter by coat slug." },
          "per_page": { "type": "integer", "default": 12, "minimum": 1, "maximum": 100 },
          "page":     { "type": "integer", "default": 1, "minimum": 1 },
          "cursor":   { "type": "string", "description": "Cursor for keyset pagination." },
          "orderby":  { "type": "string", "default": "date", "enum": ["date", "title", "name", "rand", "age"] },
          "order":    { "type": "string", "default": "DESC", "enum": ["ASC", "DESC"] },
          "exclude":  { "type": "array", "items": { "type": "integer" }, "description": "Post IDs to exclude." }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "pets":       { "type": "array", "items": { "type": "object" } },
          "total":      { "type": "integer" },
          "page":       { "type": "integer" },
          "totalPages": { "type": "integer" },
          "hasMore":    { "type": "boolean" },
          "nextCursor": { "type": "string" }
        }
      }
    },

    "petstablished/filter-pets": {
      "label": "Filter Pets",
      "description": "Retrieves filtered, paginated pets with live filter counts for each taxonomy value.",
      "category": "pets",
      "permission": "public",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "$ref": "schemas/taxonomy-filters.json",
        "type": "object",
        "properties": {
          "status":            { "type": "string", "default": "available" },
          "color":             { "type": "string" },
          "coat":              { "type": "string" },
          "search":            { "type": "string", "description": "Search by pet name and breed." },
          "goodWithDogs":      { "type": "boolean" },
          "goodWithCats":      { "type": "boolean" },
          "goodWithKids":      { "type": "boolean" },
          "shotsCurrent":      { "type": "boolean" },
          "spayedNeutered":    { "type": "boolean" },
          "housebroken":       { "type": "boolean" },
          "specialNeeds":      { "type": "boolean" },
          "hypoallergenic":    { "type": "boolean" },
          "declawed":          { "type": "boolean" },
          "showFavoritesOnly": { "type": "boolean", "default": false },
          "per_page":          { "type": "integer", "default": 12, "minimum": 1, "maximum": 100 },
          "page":              { "type": "integer", "default": 1, "minimum": 1 },
          "orderby":           { "type": "string", "default": "date", "enum": ["date", "title", "name", "rand", "age"] },
          "order":             { "type": "string", "default": "DESC", "enum": ["ASC", "DESC"] }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": ["pets", "total", "page", "totalPages", "counts"],
        "properties": {
          "pets":       { "type": "array", "items": { "type": "object" } },
          "total":      { "type": "integer" },
          "page":       { "type": "integer" },
          "totalPages": { "type": "integer" },
          "counts": {
            "type": "object",
            "description": "Per-taxonomy and per-compatibility-filter counts given currently active filters.",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "value": { "type": "string" },
                  "label": { "type": "string" },
                  "count": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    },

    "petstablished/batch-get-pets": {
      "label": "Batch Get Pets",
      "description": "Retrieves multiple pets by their post IDs in one request.",
      "category": "pets",
      "permission": "public",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "required": ["ids"],
        "properties": {
          "ids": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "Array of pet post IDs."
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "pets":    { "type": "array", "items": { "type": "object" } },
          "missing": { "type": "array", "items": { "type": "integer" } }
        }
      }
    },

    "petstablished/get-filter-options": {
      "label": "Get Filter Options",
      "description": "Retrieves all available filter values from pet taxonomies with term counts.",
      "category": "pets",
      "permission": "public",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "description": "Map of taxonomy key to array of { value, label, count } options.",
        "additionalProperties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        }
      }
    },

    "petstablished/toggle-favorite": {
      "label": "Toggle Favorite",
      "description": "Adds or removes a pet from the current user's favorites list.",
      "category": "pets",
      "permission": "public_with_session",
      "meta": {
        "annotations": {
          "readonly": false,
          "destructive": false,
          "idempotent": false
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Pet post ID to toggle."
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": ["favorited", "favorites"],
        "properties": {
          "favorited": { "type": "boolean", "description": "Whether the pet is now favorited." },
          "favorites": { "type": "array", "items": { "type": "integer" }, "description": "Updated favorites list." }
        }
      }
    },

    "petstablished/get-favorites": {
      "label": "Get Favorites",
      "description": "Retrieves the current user's favorite pet IDs and hydrated pet data.",
      "category": "pets",
      "permission": "public_with_session",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "favorites": { "type": "array", "items": { "type": "integer" } },
          "pets":      { "type": "array", "items": { "type": "object" } }
        }
      }
    },

    "petstablished/clear-favorites": {
      "label": "Clear All Favorites",
      "description": "Removes all pets from the current user's favorites list in a single operation.",
      "category": "pets",
      "permission": "public_with_session",
      "meta": {
        "annotations": {
          "readonly": false,
          "destructive": true,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": ["favorites"],
        "properties": {
          "favorites": { "type": "array", "items": { "type": "integer" }, "description": "Empty favorites list." }
        }
      }
    },

    "petstablished/update-comparison": {
      "label": "Update Comparison",
      "description": "Manages the pet comparison list: add, remove, clear, or set pets.",
      "category": "pets",
      "permission": "public_with_session",
      "meta": {
        "annotations": {
          "readonly": false,
          "destructive": false,
          "idempotent": false
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["add", "remove", "clear", "set"],
            "description": "The comparison operation to perform."
          },
          "id": {
            "type": "integer",
            "description": "Pet post ID (for add/remove)."
          },
          "ids": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "Pet post IDs (for set)."
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": ["ids", "count", "max"],
        "properties": {
          "ids":      { "type": "array", "items": { "type": "integer" } },
          "pets":     { "type": "array", "items": { "type": "object" } },
          "count":    { "type": "integer" },
          "max":      { "type": "integer" },
          "shareUrl": { "type": "string" }
        }
      }
    },

    "petstablished/get-comparison": {
      "label": "Get Comparison",
      "description": "Retrieves the current comparison list with hydrated pet data and share URL.",
      "category": "pets",
      "permission": "public_with_session",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ids":      { "type": "array", "items": { "type": "integer" } },
          "pets":     { "type": "array", "items": { "type": "object" } },
          "count":    { "type": "integer" },
          "max":      { "type": "integer" },
          "shareUrl": { "type": "string" }
        }
      }
    },

    "petstablished/get-adoption-stats": {
      "label": "Get Adoption Stats",
      "description": "Retrieves aggregate adoption statistics for use in block bindings and archive pages.",
      "category": "pets",
      "permission": "public",
      "meta": {
        "annotations": {
          "readonly": true,
          "destructive": false,
          "idempotent": true
        },
        "show_in_rest": true
      },
      "input_schema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "default": "available",
            "description": "Filter by pet status."
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "available_count":     { "type": "integer", "description": "Total available pets." },
          "available_by_species": { "type": "string", "description": "Formatted string: '23 Dogs, 8 Cats'." },
          "species_counts": {
            "type": "object",
            "description": "Count per animal type.",
            "additionalProperties": { "type": "integer" }
          },
          "newest_pet_name":   { "type": "string" },
          "newest_pet_id":     { "type": "integer" },
          "total_pets":        { "type": "integer", "description": "All pets regardless of status." },
          "last_sync":         { "type": "string", "description": "ISO 8601 timestamp of last sync." }
        }
      }
    }
  }
}