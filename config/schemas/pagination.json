{
  "$id": "pagination",
  "type": "object",
  "description": "Standard pagination parameters shared across list/filter abilities.",
  "properties": {
    "page": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Page number (1-based)."
    },
    "per_page": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 12,
      "description": "Items per page."
    }
  }
}
